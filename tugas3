<!DOCTYPE html>
<html>
<head>
<title>Latihan Tabel Responsif</title>

<style>

table{
    border-collapse: collapse;
    width:100%;
    min-width:600px;
}

th,td{
    border:1px solid black;
    padding:8px;
    text-align:center;
}

th{
    background:#2c7be5;   /* ganti warna biru */
    color:white;
}

.table-wrapper{
    overflow-x:auto;
}

@media screen and (max-width:600px){

table, thead, tbody, th, td, tr{
    display:block;
}

thead tr{
    display:none;
}

tr{
    margin-bottom:15px;
}

td{
    text-align:left;
    padding-left:50%;
    position:relative;
}

td::before{
    content: attr(data-label);
    position:absolute;
    left:10px;
    font-weight:bold;
}

}

</style>
</head>

<body>

<h2>Data Mahasiswa Informatika</h2>

<div class="table-wrapper">
<table>

<thead>
<tr>
    <th>Nama</th>
    <th>NIM</th>
    <th>Kelas</th>
    <th>Semester</th>
</tr>
</thead>

<tbody>
<tr>
    <td data-label="Nama">Cherlie</td>
    <td data-label="NIM">1125102219</td>
    <td data-label="Kelas">SP.2</td>
    <td data-label="Semester">2</td>
</tr>

<tr>
    <td data-label="Nama">Randhi</td>
    <td data-label="NIM">1125102226</td>
    <td data-label="Kelas">SP.2</td>
    <td data-label="Semester">2</td>
</tr>

<tr>
    <td data-label="Nama">Budi</td>
    <td data-label="NIM">1125102233</td>
    <td data-label="Kelas">SP.2</td>
    <td data-label="Semester">2</td>
</tr>

</tbody>
</table>
</div>

</body>
</html>